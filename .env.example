# FrontPrep - Appwrite configuration

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id

# Collections
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=categories
VITE_APPWRITE_QUESTIONS_COLLECTION_ID=questions

# Server-side (Node scripts: setupCollections/testConnection)
APPWRITE_API_KEY=your_appwrite_api_key_with_db_permissions

